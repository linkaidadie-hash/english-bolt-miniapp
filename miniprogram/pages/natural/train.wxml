<view class="page" wx:if="{{!audioReady}}">
  <view class="empty">
    <text class="empty-icon">📭</text>
    <text class="empty-title">音频未就绪</text>
    <text class="empty-text">本课程暂时没有真实音频, 请先到自然首页查看音频就绪状态。</text>
    <button class="btn" bindtap="onExit">返回</button>
  </view>
</view>

<view class="page" wx:elif="{{finished}}">
  <view class="finish-card">
    <view class="finish-icon">🎉</view>
    <view class="finish-title">本轮完成</view>
    <view class="finish-stats">
      <view class="stat">
        <text class="stat-num">{{progress.done}}</text>
        <text class="stat-label">完成</text>
      </view>
      <view class="stat">
        <text class="stat-num">{{progress.correct}}</text>
        <text class="stat-label">答对</text>
      </view>
      <view class="stat">
        <text class="stat-num">{{progress.passRate}}%</text>
        <text class="stat-label">正确率</text>
      </view>
    </view>
    <view class="finish-actions">
      <button class="btn" bindtap="onRestart">再来一轮</button>
      <button class="btn btn-secondary" bindtap="onExit">返回课程</button>
    </view>
  </view>
</view>

<view class="page" wx:elif="{{pool.length > 0 && pool[idx]}}">
  <!-- 顶部进度条 -->
  <view class="top-bar">
    <view class="top-bar-text muted">{{modeMeta.icon}} {{modeMeta.name}} · {{idx + 1}}/{{progress.total}}</view>
    <view class="top-bar-progress">
      <view class="progress-fill" style="width: {{progress.done / progress.total * 100}}%"></view>
    </view>
  </view>

  <!-- ============== mode 1: listen-and-guess ============== -->
  <block wx:if="{{mode === 'listen-and-guess'}}">
    <view class="card mode-hero">
      <view class="mode-desc">{{modeMeta.desc}}</view>
    </view>

    <view class="card audio-card">
      <view class="audio-row">
        <button class="btn-audio" hover-class="btn-audio-hover" bindtap="onReplayGuess">🔊 听自然</button>
        <text class="audio-hint muted">点按钮听自然语速发音</text>
      </view>
    </view>

    <view class="section-title">4 选 1 · 选原句</view>
    <view class="options-list">
      <view
        wx:for="{{options}}"
        wx:key="idx"
        wx:for-item="opt"
        class="opt-card {{picked === opt.idx ? (opt.isCorrect ? 'opt-correct' : 'opt-wrong') : ''}} {{picked !== null && opt.isCorrect ? 'opt-correct-show' : ''}}"
        hover-class="opt-hover"
        hover-stay-time="100"
        bindtap="onPickOption"
        data-idx="{{opt.idx}}"
      >
        <text class="opt-letter">{{['A','B','C','D'][opt.idx]}}</text>
        <text class="opt-text">{{opt.text}}</text>
        <text wx:if="{{picked !== null && opt.isCorrect}}" class="opt-mark">✓</text>
        <text wx:elif="{{picked === opt.idx && !opt.isCorrect}}" class="opt-mark opt-mark-wrong">✗</text>
      </view>
    </view>

    <view wx:if="{{guessResult}}" class="result-card {{guessResult === 'correct' ? 'result-ok' : 'result-bad'}}">
      <text wx:if="{{guessResult === 'correct'}}" class="result-text">🎉 答对了！</text>
      <text wx:else class="result-text">😅 正确答案已标出，再听一遍</text>
      <button class="btn" hover-class="btn-hover" bindtap="onNext">{{idx + 1 >= progress.total ? '完成' : '下一题'}}</button>
    </view>
  </block>

  <!-- ============== mode 2: sound-to-words ============== -->
  <block wx:elif="{{mode === 'sound-to-words'}}">
    <view class="card mode-hero">
      <view class="mode-desc">{{modeMeta.desc}}</view>
    </view>

    <view class="card audio-card">
      <view class="audio-row">
        <button class="btn-audio" hover-class="btn-audio-hover" bindtap="onReplayNatural" data-when="intro">🔊 听自然</button>
        <text class="audio-hint muted">先听自然, 然后听慢速分段, 拼回原句</text>
      </view>
    </view>

    <view class="section-title">慢速分段 · 点选拼句</view>
    <view class="chunks-pool">
      <view
        wx:for="{{chunks}}"
        wx:key="idx"
        wx:for-item="c"
        class="chunk-card {{c.used ? 'chunk-used' : ''}}"
        hover-class="chunk-hover"
        hover-stay-time="100"
        bindtap="onPickWord"
        bindlongtap="onPlayWordOnly"
        data-idx="{{index}}"
      >
        <text class="chunk-text">{{c.text}}</text>
      </view>
    </view>

    <view wx:if="{{selectedWords.length > 0}}" class="selected-bar">
      <text class="muted">你拼的：</text>
      <block wx:for="{{selectedWords}}" wx:key="*this" wx:for-item="si" wx:for-index="sIdx">
        <text class="sel-token {{wordResult === 'wrong' && wrongPositions[sIdx] !== undefined ? 'sel-token-wrong' : ''}} {{wordResult === 'correct' ? 'sel-token-correct' : ''}}">{{chunks[si].text}}</text>
      </block>
    </view>

    <view class="action-row" wx:if="{{wordResult === null}}">
      <button class="btn btn-secondary" hover-class="btn-hover" bindtap="onClearWords" disabled="{{selectedWords.length === 0}}">🗑 清空</button>
      <button class="btn btn-secondary" hover-class="btn-hover" bindtap="onUndoWord" disabled="{{selectedWords.length === 0}}">↩ 撤销</button>
      <button class="btn" hover-class="btn-hover" bindtap="onConfirmWords" disabled="{{selectedWords.length !== chunks.length}}">确认</button>
    </view>

    <!-- 提交后: 错题显示正确答案 + 播放 natural + 变化点 -->
    <view wx:if="{{wordResult === 'correct'}}" class="result-card result-ok">
      <text class="result-text">🎉 拼对了！</text>
      <button class="btn-audio" hover-class="btn-audio-hover" bindtap="onReplayNatural">🔊 再听自然</button>
      <button class="btn" hover-class="btn-hover" bindtap="onNext">{{idx + 1 >= progress.total ? '完成' : '下一题'}}</button>
    </view>

    <view wx:elif="{{wordResult === 'wrong'}}" class="result-card result-bad">
      <text class="result-text">😅 顺序错了，错位已标红</text>
      <view class="correct-line">
        <text class="muted">正确顺序：</text>
        <block wx:for="{{correctOrder}}" wx:key="*this" wx:for-item="oi">
          <text class="sel-token sel-token-correct">{{chunks[oi].text}}</text>
        </block>
      </view>
      <button class="btn-audio" hover-class="btn-audio-hover" bindtap="onReplayNatural">🔊 听自然</button>
      <button class="btn" hover-class="btn-hover" bindtap="onNext">{{idx + 1 >= progress.total ? '完成' : '下一题'}}</button>
    </view>

    <!-- 错题时显示变化点 (提交后) -->
    <view wx:if="{{wordResult && pool[idx].pronunciationNotes && pool[idx].pronunciationNotes.length}}" class="card notes-card">
      <view class="notes-label">🎯 自然语速变化点</view>
      <view wx:for="{{pool[idx].pronunciationNotes}}" wx:key="*this" wx:for-item="n" class="note-line">• {{n}}</view>
    </view>
  </block>

  <!-- ============== mode 3: slow-vs-natural ============== -->
  <block wx:elif="{{mode === 'slow-vs-natural'}}">
    <view class="card mode-hero">
      <view class="mode-desc">{{modeMeta.desc}}</view>
    </view>

    <view class="compare-grid">
      <view class="compare-card">
        <view class="compare-label">🐢 慢速</view>
        <view class="compare-text">{{pool[idx].clearText}}</view>
        <button class="btn-audio" hover-class="btn-audio-hover" bindtap="onPlayClear">▶ 播放</button>
      </view>
      <view class="compare-card">
        <view class="compare-label">🐇 自然</view>
        <view class="compare-text compare-natural">{{pool[idx].naturalText}}</view>
        <button class="btn-audio" hover-class="btn-audio-hover" bindtap="onPlayNatural">▶ 播放</button>
      </view>
    </view>

    <view class="card ipa-card">
      <view class="ipa-row">
        <text class="ipa-label muted">标准 IPA</text>
        <text class="ipa-text">{{pool[idx].standardIpa}}</text>
      </view>
      <view class="ipa-row">
        <text class="ipa-label muted">自然 IPA</text>
        <text class="ipa-text ipa-natural">{{pool[idx].naturalIpa}}</text>
      </view>
    </view>

    <view wx:if="{{pool[idx].pronunciationNotes && pool[idx].pronunciationNotes.length}}" class="card notes-card">
      <view class="notes-label">🎯 变化点</view>
      <view wx:for="{{pool[idx].pronunciationNotes}}" wx:key="*this" wx:for-item="n" class="note-line">• {{n}}</view>
    </view>

    <view class="action-row">
      <button class="btn" hover-class="btn-hover" bindtap="onNext">{{idx + 1 >= progress.total ? '完成' : '下一句'}}</button>
    </view>
  </block>

  <!-- 公共: 翻译 -->
  <view class="card trans-card">
    <view class="trans-label muted">中文</view>
    <view class="trans-text">{{pool[idx].translation}}</view>
  </view>

  <view class="footer-note muted">
    阶段四 B · 训练模式 v2
  </view>
</view>
