.page {
  padding: 24rpx 0 64rpx;
}

.meta-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  font-size: 22rpx;
  padding: 0 32rpx 16rpx;
}
.meta-bar .dot { color: var(--c-text-faint); }
.meta-bar .ok  { color: #10b981; }
.meta-bar .warn{ color: #f59e0b; }

.word-card .counter {
  font-size: 24rpx;
  margin-bottom: 12rpx;
}
.word-card .word-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.word {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--c-text);
  letter-spacing: 1rpx;
  word-break: break-all;
}
.pos {
  font-size: 26rpx;
  color: var(--c-text-faint);
  font-style: italic;
}
.ipa {
  font-size: 30rpx;
  color: var(--c-text-dim);
  margin-top: 8rpx;
  font-family: "Charis SIL", "Doulos SIL", "Times New Roman", serif;
}
.meaning {
  font-size: 30rpx;
  color: var(--c-text);
  margin-top: 16rpx;
  font-weight: 500;
  line-height: 1.5;
}
.meta {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}
.tag {
  font-size: 22rpx;
  color: var(--c-text-dim);
  background: #f2f2f2;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}
.play-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 32rpx;
}
.play-btn {
  flex: 0 0 auto;
  min-width: 240rpx;
}
.play-btn.playing {
  background: #d35454;
}
.status {
  font-size: 22rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}
.error {
  margin-top: 16rpx;
  color: #d35454;
  font-size: 24rpx;
}

.exchange {
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--c-border);
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  font-size: 22rpx;
}
.exch-label { font-size: 22rpx; }
.exch-val {
  color: var(--c-text-dim);
  background: #fafafa;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.nav-card { padding: 16rpx 24rpx; }
.nav-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.nav-row .muted {
  font-size: 28rpx;
  font-weight: 500;
}

.training-card { padding: 24rpx; }
.training-card .card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.training-row {
  display: flex; gap: 12rpx; justify-content: space-between;
}
.training-btn {
  flex: 1; min-height: 80rpx; font-size: 26rpx;
  background: var(--c-primary-dim); color: var(--c-primary);
  border: 1rpx solid var(--c-primary);
  padding: 12rpx 8rpx;
}
.training-btn:active { opacity: 0.7; }

.word-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}
.word-pill {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: #f7f7f7;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--c-text);
  border: 2rpx solid transparent;
}
.word-pill.active {
  background: var(--c-primary);
  color: #fff;
  border-color: var(--c-primary);
}
.word-pill.missing .pill-word { color: var(--c-text-faint); }
.word-pill .pill-status {
  font-size: 18rpx;
  opacity: 0.7;
}
.word-pill.active .pill-status { opacity: 1; }

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 16rpx;
}
.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--c-border);
}
.setting-row:last-child { border-bottom: none; }
.switch {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
}
.switch.on  { color: #fff; background: var(--c-primary); }
.switch.off { color: var(--c-text-faint); background: #eee; }

.check-item {
  font-size: 26rpx;
  color: var(--c-text-dim);
  padding: 10rpx 0;
  padding-left: 28rpx;
  position: relative;
}
.check-item::before {
  content: "·";
  position: absolute;
  left: 8rpx;
  color: var(--c-primary);
  font-size: 36rpx;
  line-height: 1;
}
