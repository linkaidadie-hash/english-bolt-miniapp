.page { padding: 24rpx 0 64rpx; }
.meta-bar { display: flex; gap: 12rpx; font-size: 22rpx; padding: 0 32rpx 16rpx; }

.quiz-meta { font-size: 24rpx; margin-bottom: 24rpx; text-align: center; }

.hint-block {
  padding: 32rpx; background: #E8F1FC; border-radius: 12rpx;
  margin-bottom: 24rpx; text-align: center;
}
.hint-meaning { font-size: 32rpx; color: #333; line-height: 1.6; }

/* P0-2 2026-07-19: 词性 / 释义 / 音标 独立展示样式 */
.hint-pos {
  margin-bottom: 16rpx;
  text-align: center;
}
.pos-label {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: #4A90E2;
  color: #fff;
  font-size: 22rpx;
  border-radius: 8rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}
.hint-meanings {
  display: flex; flex-direction: column;
  align-items: flex-start;
  text-align: left;
  margin: 16rpx 0;
  padding: 0 16rpx;
}
.hint-meaning-line {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  margin: 2rpx 0;
}
.hint-ipa {
  margin-top: 12rpx;
  text-align: center;
  padding-top: 12rpx;
  border-top: 1rpx dashed #b8d4f0;
}
.ipa-text {
  font-size: 26rpx;
  color: #4A90E2;
  font-style: italic;
  font-family: "Times New Roman", serif;
  letter-spacing: 1rpx;
}

.feedback-detail {
  display: flex; flex-direction: column;
  margin-top: 12rpx;
  padding: 16rpx;
  background: #f9fafb;
  border-radius: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
}
.feedback-meaning-line {
  display: block;
  padding-left: 16rpx;
}

.spell-input {
  width: 100%; height: 96rpx; font-size: 36rpx;
  border: 2rpx solid #ddd; border-radius: 12rpx;
  padding: 0 24rpx; text-align: center; letter-spacing: 4rpx;
  box-sizing: border-box;
}
.spell-input.correct { border-color: #10b981; background: #d1fae5; }
.spell-input.wrong   { border-color: #ef4444; background: #fee2e2; }
.placeholder { color: #ccc; }

.action-row {
  display: flex; gap: 16rpx; justify-content: center; margin-top: 32rpx;
}
.action-row button { flex: 1; max-width: 320rpx; }

.feedback {
  margin-top: 24rpx; padding-top: 24rpx;
  border-top: 1rpx solid #eee;
  display: flex; flex-direction: column; gap: 8rpx;
  font-size: 26rpx;
}

.card-title { font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; }
.stat-row { display: flex; justify-content: space-around; }
.stat { text-align: center; }
.stat-num { font-size: 56rpx; font-weight: 700; color: #4A90E2; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.muted { color: #999; }
.ok { color: #10b981; font-weight: 600; }
