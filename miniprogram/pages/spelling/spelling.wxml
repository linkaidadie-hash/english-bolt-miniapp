<view class="page">
  <view class="meta-bar muted">
    <text wx:if="{{!summary}}">{{currentIndex + 1}} / {{quiz.length}}</text>
    <text wx:else>训练完成</text>
  </view>

  <block wx:if="{{!summary}}">
    <view class="card" wx:if="{{quiz.length > 0}}">
      <view class="quiz-meta muted">拼写检测 · 根据释义拼单词</view>

      <!-- P0-2 修复 2026-07-19: 释义 / 词性 / 音标 独立展示, 不再混合 -->
      <view class="hint-block">
        <!-- 词性独立显示 (在释义之上) -->
        <view class="hint-pos" wx:if="{{quiz[currentIndex].posLabel}}">
          <text class="pos-label">{{quiz[currentIndex].posLabel}}</text>
        </view>

        <!-- 中文释义: 多义项逐条列出 (≥2 高频义项) -->
        <view class="hint-meanings">
          <text wx:if="{{quiz[currentIndex].meanings.length === 0}}" class="muted">（暂无中文释义）</text>
          <text
            wx:for="{{quiz[currentIndex].meanings}}"
            wx:key="*this"
            wx:for-item="m"
            wx:for-index="mi"
            class="hint-meaning-line"
          >• {{m}}</text>
        </view>

        <!-- 音标独立显示 (在释义之下, 用斜体) -->
        <view class="hint-ipa" wx:if="{{quiz[currentIndex].ipa}}">
          <text class="ipa-text">/{{quiz[currentIndex].ipa}}/</text>
        </view>
      </view>

      <input
        class="spell-input {{showFeedback ? (isCorrect ? 'correct' : 'wrong') : ''}}"
        type="text"
        value="{{inputValue}}"
        bindinput="onInput"
        placeholder="请输入单词"
        placeholder-class="placeholder"
        disabled="{{showFeedback}}"
        confirm-type="done"
        bindconfirm="onSubmit"
      />

      <view class="action-row">
        <button wx:if="{{!showFeedback}}" class="primary" bindtap="onSubmit" disabled="{{!inputValue}}">提交</button>
        <button wx:else class="primary" bindtap="onNext">下一题</button>
      </view>

      <view class="feedback" wx:if="{{showFeedback}}">
        <text class="muted">{{quality === 'remembered' ? '✅ 拼写正确' : (quality === 'vague' ? '⚠️ 接近正确（1 字符内）' : '❌ 拼错了')}}</text>
        <text class="muted">正确: <text class="ok">{{quiz[currentIndex].expected}}</text></text>
        <!-- 反馈区: 同样独立显示词性/释义/音标 -->
        <view class="feedback-detail">
          <text wx:if="{{quiz[currentIndex].posLabel}}" class="muted">词性: {{quiz[currentIndex].posLabel}}</text>
          <text class="muted">释义:</text>
          <text
            wx:for="{{quiz[currentIndex].meanings}}"
            wx:key="*this"
            wx:for-item="m"
            class="muted feedback-meaning-line"
          >  • {{m}}</text>
          <text wx:if="{{quiz[currentIndex].ipa}}" class="muted">音标: /{{quiz[currentIndex].ipa}}/</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="card-title">拼写训练完成</view>
      <view class="stat-row">
        <view class="stat">
          <view class="stat-num">{{summary.total}}</view>
          <view class="stat-label">题数</view>
        </view>
        <view class="stat">
          <view class="stat-num">{{summary.durationMs/1000}}s</view>
          <view class="stat-label">耗时</view>
        </view>
      </view>
      <view class="action-row" style="margin-top: 32rpx;">
        <button class="primary" bindtap="onBack">完成</button>
      </view>
    </view>
  </block>
</view>
