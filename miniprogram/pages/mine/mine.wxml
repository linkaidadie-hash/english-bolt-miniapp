<view class="page">
  <view class="card profile">
    <view class="avatar"></view>
    <view class="meta">
      <view class="name">英语快充 v2</view>
      <view class="muted">build: {{buildTag}}</view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">能力进度（5 维度）</view>
    <view class="stat-grid">
      <view class="stat">
        <view class="stat-num">{{stats.known}}</view>
        <view class="stat-label">认识词汇</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{stats.listen}}</view>
        <view class="stat-label">标准听力</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{stats.spell}}</view>
        <view class="stat-label">拼写</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{stats.speak}}</view>
        <view class="stat-label">会说</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{stats.naturalListen}}</view>
        <view class="stat-label">自然口语</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{stats.mastered}}</view>
        <view class="stat-label">已掌握</view>
      </view>
    </view>
    <view class="muted small">答对一次计入对应维度；间隔复习按 SRS 自动调度</view>
  </view>

  <view class="card">
    <view class="card-title">训练统计</view>
    <view class="stat-row">
      <view class="stat">
        <view class="stat-num">{{trainingCount}}</view>
        <view class="stat-label">总答题数</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{stats.total}}</view>
        <view class="stat-label">已学词数</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">数据</view>
    <view class="data-row">
      <text>词库来源</text>
      <text class="muted">ECDICT 1.0.3 (CC-BY-SA 4.0) · BNC 词频</text>
    </view>
    <view class="data-row">
      <text>音频</text>
      <text class="muted">已就绪 830 / 缺失 2170</text>
    </view>
    <view class="data-row">
      <text>训练源</text>
      <text class="muted">仅 830 ready 词（阶段三）</text>
    </view>
  </view>
</view>
