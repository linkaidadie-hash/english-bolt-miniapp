<view class="page">
  <view class="card profile">
    <view class="avatar">📘</view>
    <view class="meta">
      <view class="name">Vocora</view>
      <view class="muted small">build: {{buildTag}}</view>
    </view>
  </view>

  <view class="card" bindtap="onGoTask" hover-class="card-hover">
    <view class="task-row">
      <view class="task-icon">🎯</view>
      <view class="task-meta">
        <view class="task-name">今日现实任务</view>
        <view class="task-sub muted">每天 1 个 · 连续 {{taskStreak}} 天</view>
      </view>
      <text class="muted">›</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">能力进度 (5 维度)</view>
    <view class="stat-grid">
      <view class="stat">
        <view class="stat-num">{{stats.known}}</view>
        <view class="stat-label">认识词汇</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{stats.listen}}</view>
        <view class="stat-label">标准听力</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{stats.spell}}</view>
        <view class="stat-label">拼写</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{stats.speak}}</view>
        <view class="stat-label">会说</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{stats.naturalListen}}</view>
        <view class="stat-label">自然口语</view>
      </view>
      <view class="stat">
        <view class="stat-num">{{stats.mastered}}</view>
        <view class="stat-label">已掌握</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">学习进度</view>
    <view class="data-row">
      <text>训练总答题数</text>
      <text class="muted">{{trainingCount}}</text>
    </view>
    <view class="data-row">
      <text>已学词数</text>
      <text class="muted">{{stats.total}}</text>
    </view>
    <view class="data-row">
      <text>场景通关</text>
      <text class="muted">{{sceneDone}} / {{sceneTotal}}</text>
    </view>
    <view class="data-row" wx:if="{{storageStats}}">
      <text>本地存储</text>
      <text class="muted">{{storageStats.totalSizeKB}} KB / {{storageStats.limitKB}} KB</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">设置与法律</view>
    <view class="link-row" hover-class="link-hover" bindtap="onGoPrivacy">
      <text>📄 隐私说明</text>
      <text class="muted">›</text>
    </view>
    <view class="link-row" hover-class="link-hover" bindtap="onGoRecordPerm">
      <text>🎙️ 录音权限用途</text>
      <text class="muted">›</text>
    </view>
    <view class="link-row" hover-class="link-hover" bindtap="onGoAbout">
      <text>ℹ️ 关于</text>
      <text class="muted">›</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">数据管理</view>
    <view class="muted small">清除所有学习数据, 词库本身不受影响。不可恢复。</view>
    <button class="btn btn-danger" bindtap="onClearData">🗑 清除所有学习数据</button>
  </view>
</view>
